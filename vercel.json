{
    "version": 2,
    "builds": [
        {
            "src": "backend/src/app.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": "backend/data/chunks.json"
            }
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/src/app.js"
        },
        {
            "source": "/(.*)",
            "destination": "frontend/$1"
        }
    ]
}